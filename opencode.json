{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "patch": "ask",
    "webfetch": "allow",
    "todowrite": "allow",
    "external_directory": "ask"
  },
  "command": {
    "commit": {
      "template": "Git commit current changes, write comment as detail as possible.",
      "description": "Do git commit",
      "agent": "build"
    }
  }
}
